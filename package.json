{
  "name": "cli2port",
  "version": "0.1.0",
  "description": "Expose local Claude Code / Codex CLIs as an OpenAI- and Anthropic-compatible HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cli2port": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:anthropic": "tsx scripts/smoke-anthropic.ts"
  },
  "keywords": [
    "claude",
    "codex",
    "openai",
    "proxy",
    "cli",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "openai": "^6.45.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
