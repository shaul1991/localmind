# localmind 설정 (모두 선택 사항 — 기본값으로도 동작)

# 서버가 바인딩할 포트와 호스트
PORT=8787
HOST=127.0.0.1

# 클라이언트 인증용 키. 설정하면 Authorization: Bearer <키> 헤더 필수.
# 비워두면 인증 없이 누구나 호출 가능 (로컬 전용 권장).
LOCALMIND_API_KEY=

# 모델명으로 백엔드를 판별하지 못했을 때 사용할 기본 백엔드 (claude | codex)
DEFAULT_BACKEND=claude

# 백엔드별 기본 모델 (요청 model 필드가 별칭만 줄 때 사용)
CLAUDE_DEFAULT_MODEL=sonnet
CODEX_DEFAULT_MODEL=gpt-5.5

# CLI 실행 파일 경로 (PATH에 있으면 그대로 두어도 됨)
CLAUDE_BIN=claude
CODEX_BIN=codex

# 단일 요청 타임아웃 (밀리초)
REQUEST_TIMEOUT_MS=300000

# 세션 영속화 모드 (off | explicit | auto)
#   off:      항상 stateless (매 요청 전체 히스토리 전송)
#   explicit: x-localmind-session 헤더 / session_id / user 필드가 있을 때만 resume
#   auto:     메시지 prefix를 자동 인식해 투명하게 resume (기본값)
SESSION_MODE=auto

# 세션 매핑 보관 시간(ms)과 최대 개수
SESSION_TTL_MS=3600000
SESSION_MAX=1000

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info

# ── Docker gateway 프로파일 (docker compose --profile gateway) ──
# 임베딩 모델 (ollama가 자동 pull). 한국어 섞인 노트엔 bge-m3 권장.
EMBEDDING_MODEL=bge-m3
# 게이트웨이(LiteLLM) 인증 키. 소비자는 이 값을 Authorization: Bearer로 보낸다.
LITELLM_MASTER_KEY=sk-local

# ── Docker memory 프로파일 (OpenMemory) ──────────────────────
# OpenMemory 메모리 추출에 쓸 채팅 모델 (게이트웨이가 claude로 라우팅)
CHAT_MODEL=claude-sonnet-4-6
# 임베딩 벡터 차원 (bge-m3=1024). EMBEDDING_MODEL을 바꾸면 이 값도 맞출 것.
EMBEDDING_DIMS=1024
# OpenMemory가 시드하는 기본 사용자 id, 노출 포트
OPENMEMORY_USER=localmind
OPENMEMORY_PORT=8767

# ── Docker mcp 프로파일 (원격 MCP, docker compose --profile mcp) ──
# 네트워크 노출용 Bearer 토큰. 비우면 mcp-http 컨테이너가 기동 거부(필수).
# 클라이언트는 Authorization: Bearer <이 값> 헤더로 접속.
MCP_HTTP_TOKEN=
# 디바이스/서버 식별자. 서버마다 다르게 주면 메모리·노트가 인스턴스별로 격리된다.
# (예: db-server, app-server-1) 메모리 user_id 기본값으로도 쓰인다.
MCP_INSTANCE=localmind
# 노트 폴더(호스트 경로). 이 서버가 관리할 자원/지식 노트의 정본.
NOTES_DIR=
# MCP 도구 ask/ask_brain이 쓸 기본 모델
MCP_DEFAULT_MODEL=sonnet
