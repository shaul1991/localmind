{
  "name": "localmind",
  "version": "2026.07.8",
  "description": "로컬 second-brain — 내 노트(.md)가 정본인 개인 기억 계층: capture·검색·백업·동기화 + MCP",
  "type": "module",
  "main": "dist/mcp.js",
  "bin": {
    "localmind-mcp": "dist/mcp.js"
  },
  "scripts": {
    "mcp": "tsx src/mcp.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "smoke:brain": "tsx scripts/smoke-brain.ts",
    "reindex": "tsx scripts/reindex.ts",
    "query-report": "tsx scripts/query-report.ts",
    "brain-report": "tsx scripts/brain-report.ts",
    "retrieval:quality": "tsx scripts/retrieval-quality.ts",
    "test": "node --import tsx/esm --test src/*.test.ts scripts/*.test.mjs"
  },
  "keywords": [
    "second-brain",
    "notes",
    "mcp",
    "rag",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
