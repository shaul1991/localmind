# localmind 설정 (모두 선택 사항 — 기본값으로도 동작)

# 서버가 바인딩할 포트와 호스트
PORT=8787
HOST=127.0.0.1

# 클라이언트 인증용 키. 설정하면 Authorization: Bearer <키> 헤더 필수.
# 비워두면 인증 없이 누구나 호출 가능 (로컬 전용 권장).
# ⚠️ 공유 머신(여러 사람이 쓰는 컴퓨터·회사 노트북 등)이거나 신뢰할 수 없는 프로세스가
#   돌 수 있으면 반드시 이 키를 설정하라 — 루프백(127.0.0.1)이라도 같은 머신의 다른
#   프로세스는 무인증으로 당신의 claude/codex 구독을 소비할 수 있다.
LOCALMIND_API_KEY=

# Host 헤더 허용 목록(DNS rebinding 차단). 기본 목록(localhost·127.0.0.1·[::1]·
# localmind·host.docker.internal)에 콤마로 **추가**된다(교체 아님). 리버스 프록시 등
# 특수 구성에서 다른 호스트명으로 접근할 때만 지정. "*" 로 두면 검증을 끈다(권장하지 않음).
LOCALMIND_ALLOWED_HOSTS=

# claude(구독) 인증 토큰 — 컨테이너 claude 백엔드가 이 값으로 로그인한다.
# 호스트에서 한 번 발급: `make claude-token` (= claude setup-token, 브라우저 1회).
# 출력된 토큰을 아래에 붙여넣는다. ~1년 장수명이라 자동 갱신 불필요.
# (claude 백엔드를 안 쓰면 비워둬도 됨. codex 인증은 ~/.codex 마운트로 별도 처리)
CLAUDE_CODE_OAUTH_TOKEN=

# 모델명으로 백엔드를 판별하지 못했을 때 사용할 주(기본) 백엔드 (claude | codex | gemini)
# make setup에서 메뉴로 고를 수 있고, 부(보조) 백엔드는 모델명(gemini:/gpt: 등)으로 골라 쓴다.
DEFAULT_BACKEND=claude

# 백엔드별 기본 모델 (요청 model 필드가 별칭만 줄 때 사용)
CLAUDE_DEFAULT_MODEL=sonnet
CODEX_DEFAULT_MODEL=gpt-5.5

# CLI 실행 파일 경로 (PATH에 있으면 그대로 두어도 됨)
CLAUDE_BIN=claude
CODEX_BIN=codex

# ── Gemini 백엔드 (선택) ──────────────────────────────────────────
# Google Gemini를 세 번째 백엔드로 쓰려면 API 키를 넣는다. 요청 model이 "gemini..."이거나
# "gemini:<모델>" 프리픽스면 Gemini로 라우팅된다. 키가 없으면 claude/codex는 그대로 동작하고
# Gemini 요청에만 오류가 난다.
#   키 발급: https://aistudio.google.com/apikey (Google 계정으로 무료 발급)
#   ⚠️ 무료 티어는 Flash 계열만(2026-04 이후 Pro는 유료). 무료 모델·정확한 ID·한도는
#      AI Studio에서 확인. 최신 모델(예: gemini-3.5-flash)은 무료 티어에서 과부하(503)가
#      잦아, 기본값은 안정적인 gemini-2.5-flash로 둔다(라이브 검증 2026-07-06).
GEMINI_API_KEY=

# Gemini 기본 모델 (요청 model이 "gemini:"처럼 모델을 안 줄 때). 더 최신을 원하면
# gemini-3.5-flash / gemini-flash-latest 등으로 바꾸되 무료 티어 과부하 가능성 유의.
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Gemini OpenAI 호환 base URL (보통 그대로 둔다)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 단일 요청 타임아웃 (밀리초)
REQUEST_TIMEOUT_MS=300000

# 세션 영속화 모드 (off | explicit | auto)
#   off:      항상 stateless (매 요청 전체 히스토리 전송)
#   explicit: x-localmind-session 헤더 / session_id / user 필드가 있을 때만 resume
#   auto:     메시지 prefix를 자동 인식해 투명하게 resume (기본값)
SESSION_MODE=auto

# 세션 매핑 보관 시간(ms)과 최대 개수
SESSION_TTL_MS=3600000
SESSION_MAX=1000

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info

# ── Docker gateway 프로파일 (docker compose --profile gateway) ──
# 임베딩 모델 (ollama가 자동 pull). 한국어 섞인 노트엔 bge-m3 권장.
EMBEDDING_MODEL=bge-m3
# 임베딩 라우팅 대상(보통 직접 안 건드림 — `make embed`가 디바이스에 맞게 설정).
#   docker 기본       : http://ollama:11434/v1
#   맥 네이티브(Metal): http://host.docker.internal:11434/v1   ← make embed BACKEND=host
OLLAMA_API_BASE=http://ollama:11434/v1
# 게이트웨이(LiteLLM) 인증 키. 소비자는 이 값을 Authorization: Bearer로 보낸다.
# 비워 두면 `make init-env`/`make up`이 설치마다 다른 임의 키를 자동 생성한다(specs/014).
# 추측 가능한 고정 값(sk-local 등)을 직접 넣지 말 것.
LITELLM_MASTER_KEY=

# ── Docker memory 프로파일 (OpenMemory) ──────────────────────
# OpenMemory 메모리 추출에 쓸 채팅 모델 (게이트웨이가 claude로 라우팅)
CHAT_MODEL=claude-sonnet-4-6
# 임베딩 벡터 차원 (bge-m3=1024). EMBEDDING_MODEL을 바꾸면 이 값도 맞출 것.
EMBEDDING_DIMS=1024
# OpenMemory가 시드하는 기본 사용자 id, 노출 포트
OPENMEMORY_USER=localmind
OPENMEMORY_PORT=8767

# ── 로컬 MCP(stdio) ──────────────────────────────────────────
# 로컬 MCP는 MCP 클라이언트(Claude Desktop/Cursor 등)의 설정 env에서
# NOTES_DIR(내 노트 폴더)·OPENMEMORY_USER(내 이름)를 지정한다. README의 'MCP 서버' 참고.
# NOTES_DIR는 쉼표로 여러 폴더 가능: "work=/notes/work,life=/notes/personal" (라벨 생략 시 폴더명).

# ── 원격 MCP(HTTP — 홈서버 중앙집중, specs/045 — make mcp-serve-http) ──
# 항상 켜진 홈서버가 단일 두뇌를 HTTP로 서비스하고, 다른 기기(맥 Claude Code)가 Tailscale 사설
# URL로 붙는다(docs/home-server.md·docs/mcp.md). 미설정이면 기존 stdio 그대로(하위호환).
# MCP_TRANSPORT=http                # http로 원격 모드. 미설정/stdio면 로컬 stdio(기본)
# MCP_AUTH_TOKEN=                   # Bearer 인증 토큰(두뇌 접근권 — 유출 주의). 없으면 http 기동 거부.
#                                   #   make mcp-serve-http가 없으면 생성해 여기에 저장한다.
# MCP_HTTP_HOST=127.0.0.1           # 바인드 호스트. 기본 비공개(loopback) — 노출은 명시적 opt-in만.
# MCP_HTTP_PORT=8789                # 기본 8789(8787 스택·4000 litellm·8788 UI 회피)
# MCP_HTTP_PATH=/mcp                # MCP 엔드포인트 경로

# ── 노트 git 저장소 연결 (specs/012 — make notes-connect) ─────
# 노트를 git 저장소로 관리하면, 저장소 목록을 여기 선언하고 `make notes-connect`(또는
# `make setup`) 한 번으로 clone→NOTES_DIR 조립→Claude Code 등록까지 자동 처리한다.
# 형식: "라벨=URL,라벨=URL" (라벨 생략 시 저장소 이름). SSH·HTTPS·scp형 URL 지원.
# 예: NOTES_REPOS="work=git@github.com:<user>/work-notes.git,life=https://github.com/<user>/life-notes.git"
# ⚠️ 토큰을 URL에 박지 말 것(https://user:token@...) — SSH 키나 git credential helper 권장
#    (토큰-in-URL은 출력에서 마스킹되지만 .env 평문에 남는다).
NOTES_REPOS=
# 저장소를 받아올 위치(기본 ~/localmind-notes, 반드시 $HOME 하위). 각 저장소는 <이 폴더>/<라벨>에 clone된다.
NOTES_REPOS_DIR=

# ── 기기 동기화 (specs/031 — make device-sync) ──────────────────────────────
# 이미 함께 쓰는 다른 기기를 한 명령으로 최신화. 형식: "라벨=ssh호스트:원격_localmind_경로"
# (쉼표로 여러 대. ssh 호스트는 ~/.ssh/config 별칭 권장 — 포트 등은 거기서.)
# 예: SYNC_DEVICES="m5=m5:/home/<user>/personal/localmind"
SYNC_DEVICES=
# 원격 비대화 셸에서 node가 안 잡히는 기기(nvm 등)용 — 원격 명령 앞에 그대로 실행된다.
# ⚠️ 이 값은 원격에서 셸로 실행되는 신뢰되는 입력이다(형식 검증 불가) — .env를 복원·공유할 때 주의.
# 예: SYNC_ENV_PREP='export PATH="$HOME/.nvm/versions/node/<버전>/bin:$PATH"'
SYNC_ENV_PREP=
